# ─────────────────────────────────────────────
# Evolution API v2 — Variables de entorno
# Copiar a config/.env y completar los valores
# NUNCA commitear config/.env al repo
# ─────────────────────────────────────────────

# ── Evolution API ─────────────────────────────
# Clave global para autenticar todos los requests (generá algo con: openssl rand -hex 32)
EVOLUTION_API_KEY=change_this_to_a_secure_key

# Puerto expuesto en el host
EVOLUTION_PORT=8080

# Nivel de log: error | warn | info | debug | verbose
LOG_LEVEL=info

# ── PostgreSQL ────────────────────────────────
POSTGRES_DB=evolution
POSTGRES_USER=evolution_user
# Puerto expuesto al host para PgAdmin/DBeaver (5432 por defecto, cambiá si hay conflicto)
POSTGRES_PORT=5432
# Generá con: openssl rand -hex 16
POSTGRES_PASSWORD=change_this_postgres_password
# IMPORTANTE: el hostname debe ser "postgres" (nombre del servicio en Docker), no localhost
DATABASE_URL=postgresql://evolution_user:change_this_postgres_password@postgres:5432/evolution?schema=public

# ── Redis ─────────────────────────────────────
# Generá con: openssl rand -hex 16
REDIS_PASSWORD=change_this_redis_password
REDIS_URI=redis://:change_this_redis_password@redis:6379

# ── Gateway (FastAPI) ─────────────────────────
# Clave que el bot usa para autenticarse contra el gateway
GATEWAY_API_KEY=change_this_gateway_key

# Puerto expuesto del gateway en el host
GATEWAY_PORT=9000
# URL publica real del gateway (sin slash final), para bots/integraciones externas
# Ej: https://gateway.tu-dominio.com
PUBLIC_BASE_URL=

# Origenes permitidos para el frontend que consume el gateway.
# Separar por coma, sin slash final. Produccion debe incluir panel-evolution.
CORS_ALLOWED_ORIGINS=http://localhost:5174,http://127.0.0.1:5174
CORS_ALLOW_ORIGIN_REGEX=https?://(localhost|127\.0\.0\.1)(:\d+)?
# Activar temporalmente para diagnosticar Origin/metodo/headers CORS en logs.
CORS_DEBUG=false

# Edad maxima aceptable para eventos entrantes de Evolution.
# 0 = deshabilitado. Recomendado para produccion: 600 (10 minutos).
MAX_EVENT_AGE_SECONDS=600

# ── Webhooks globales (opcional) ──────────────
# URL a la que Evolution enviará todos los eventos si está habilitado
# En producción apuntará al gateway: http://gateway:9000/webhooks/evolution
WEBHOOK_GLOBAL_URL=
WEBHOOK_GLOBAL_ENABLED=false
