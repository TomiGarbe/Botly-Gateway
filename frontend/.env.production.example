# URL del gateway — backend FastAPI detras de Nginx en el VPS.
VITE_GATEWAY_URL=https://gateway-server.botly.com.ar

# URL publica canonica del panel en produccion (Azure Static Web Apps).
VITE_PUBLIC_APP_URL=https://gateway.botly.com.ar

# API Key del gateway — en Azure se configura como Application Setting, no se commitea
VITE_GATEWAY_API_KEY=
VITE_SHOW_LEGACY_CONNECTIONS=false
