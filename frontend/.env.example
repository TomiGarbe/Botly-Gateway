# URL del gateway — en producción es la URL de Azure Container Apps
VITE_GATEWAY_URL=http://localhost:9000

# URL publica canonica de la aplicacion en produccion.
VITE_PUBLIC_APP_URL=http://localhost:5173

# API Key del gateway — en Azure se configura como Application Setting, no se commitea
VITE_GATEWAY_API_KEY=
VITE_SHOW_LEGACY_CONNECTIONS=false
